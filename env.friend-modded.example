# Friend modded server.
#
# Use this for real Forge/Fabric/NeoForge/Quilt mods. Players usually need the
# same loader, Minecraft version, and client-side mods installed locally.
#
# For production, prefer pinning the image with a digest:
# FRIEND_MODDED_IMAGE=itzg/minecraft-server:java21@sha256:replace_with_release_digest
FRIEND_MODDED_IMAGE=itzg/minecraft-server:java21

# Pick the loader required by the mods: FORGE, FABRIC, NEOFORGE, or QUILT.
FRIEND_MODDED_TYPE=FABRIC
FRIEND_MODDED_MINECRAFT_VERSION=1.21.4

# Separate multiple mod jar URLs with commas.
# Fabric servers often also need Fabric API as one of the listed mods.
FRIEND_MODDED_MOD_URLS=https://example.com/mod-one.jar,https://example.com/mod-two.jar

FRIEND_MODDED_PORT=25565
FRIEND_MODDED_RCON_PORT=25575
FRIEND_MODDED_RCON_PASSWORD=change_me_for_friend_server
FRIEND_MODDED_MAX_PLAYERS=8
FRIEND_MODDED_MOTD=Craftalism Modded Friends Server
FRIEND_MODDED_DIFFICULTY=normal
FRIEND_MODDED_MODE=survival
FRIEND_MODDED_ONLINE_MODE=TRUE
FRIEND_MODDED_VIEW_DISTANCE=6
FRIEND_MODDED_SIMULATION_DISTANCE=4
FRIEND_MODDED_INIT_MEMORY=1G
FRIEND_MODDED_MEMORY=2G
FRIEND_MODDED_MEM_LIMIT=3g
FRIEND_MODDED_MEM_RESERVATION=2g
FRIEND_MODDED_REMOVE_OLD_MODS=FALSE
