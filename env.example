# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=craftalism
DB_PASSWORD=change_me_in_production
RCON_PASSWORD=change_me_in_production

# ── Auth Server ───────────────────────────────────────────────────────────────
# Public URL of this auth server (used as JWT issuer claim)
AUTH_ISSUER_URI=https://auth.example.com
AUTH_TOKEN_PATH=http://craftalism-auth-server:9000/oauth2/token

# ── Host Port Bindings ────────────────────────────────────────────────────────
# Production behind craftalism-infra should keep these on loopback only.
AUTH_SERVER_HOST=127.0.0.1
AUTH_SERVER_PORT=9000
API_HOST=127.0.0.1
API_PORT=3000
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8080

# ── Runtime Profile ───────────────────────────────────────────────────────────
# Controls deployment-owned memory defaults for compose-managed services.
# Supported values: small-host, standard
CRAFTALISM_RUNTIME_PROFILE=small-host
# Uncomment only when you need a per-service override instead of the selected
# profile defaults.
# AUTH_SERVER_JAVA_TOOL_OPTIONS=-XX:InitialRAMPercentage=25 -XX:MaxRAMPercentage=45 -Xss512k -XX:+UseSerialGC -XX:MaxMetaspaceSize=96m -XX:+ExitOnOutOfMemoryError
# AUTH_SERVER_MEM_LIMIT=256m
# AUTH_SERVER_MEM_RESERVATION=192m
# API_JAVA_TOOL_OPTIONS=-XX:InitialRAMPercentage=25 -XX:MaxRAMPercentage=55 -Xss512k -XX:+UseSerialGC -XX:MaxMetaspaceSize=128m -XX:+ExitOnOutOfMemoryError
# API_MEM_LIMIT=384m
# API_MEM_RESERVATION=256m
# POSTGRES_SHARED_BUFFERS=128MB
# POSTGRES_WORK_MEM=4MB
# POSTGRES_MAINTENANCE_WORK_MEM=64MB
# POSTGRES_MEM_LIMIT=256m
# POSTGRES_MEM_RESERVATION=128m
# DASHBOARD_MEM_LIMIT=96m
# DASHBOARD_MEM_RESERVATION=32m
# EDGE_MEM_LIMIT=128m
# EDGE_MEM_RESERVATION=64m

# ── Minecraft Server Client ───────────────────────────────────────────────────
MINECRAFT_CLIENT_ID=minecraft-server
# Generate a strong secret: openssl rand -base64 32
MINECRAFT_CLIENT_SECRET=change_me_in_production
# MINECRAFT_INIT_MEMORY=512M
# MINECRAFT_MEMORY=512M
# MINECRAFT_VIEW_DISTANCE=6
# MINECRAFT_SIMULATION_DISTANCE=4
# MINECRAFT_MEM_LIMIT=768m
# MINECRAFT_MEM_RESERVATION=512m
MARKET_API_BASE_URL=http://craftalism-api:8080
MARKET_API_SNAPSHOT_PATH=/market/snapshot
MARKET_API_QUOTE_PATH=/market/quote
MARKET_API_EXECUTE_PATH=/market/execute
# MARKET_API_AUTH_TOKEN=eyJhbGciOi...
# MARKET_API_CONNECT_TIMEOUT_MS=3000
# MARKET_API_REQUEST_TIMEOUT_MS=5000
# MARKET_API_QUOTE_DEBOUNCE_TICKS=6

# ── RSA Keys ─────────────────────────────────────────────────────────────────
# Paste as single-line values using literal \n separators.
RSA_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_BASE64_KEY_HERE\n-----END PRIVATE KEY-----
RSA_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nYOUR_BASE64_KEY_HERE\n-----END PUBLIC KEY-----

# ── Production release versions (must be immutable; never use latest) ───────
AUTH_SERVER_VERSION=1.0.0
AUTH_SERVER_DIGEST=sha256:replace_with_release_digest
API_VERSION=1.0.0
API_DIGEST=sha256:replace_with_release_digest
DASHBOARD_VERSION=1.0.0
DASHBOARD_DIGEST=sha256:replace_with_release_digest
ECONOMY_VERSION=1.5
MARKET_VERSION=1.0.0
POSTGRES_VERSION=18-alpine
POSTGRES_DIGEST=sha256:replace_with_release_digest
MINECRAFT_IMAGE_VERSION=java21
MINECRAFT_IMAGE_DIGEST=sha256:replace_with_release_digest

# ── Optional standalone edge profile ──────────────────────────────────────────
# Only set these if you intentionally run the local `edge` service profile
# instead of the infra-managed host Caddy proxy.
# CADDY_IMAGE=caddy:2.9-alpine@sha256:replace_with_release_digest
# DASHBOARD_SITE_ADDRESS=dash.example.com
# AUTH_SITE_ADDRESS=auth.example.com
# DASHBOARD_BASIC_AUTH_USERNAME=craftalism
# DASHBOARD_BASIC_AUTH_PASSWORD_HASH=$$2a$$14$$replace_with_bcrypt_hash

# ── Local development overrides (optional) ───────────────────────────────────
# AUTH_SERVER_BUILD_CONTEXT=../craftalism-authorization-server/java
# API_BUILD_CONTEXT=../craftalism-api/java
# DASHBOARD_BUILD_CONTEXT=../craftalism-dashboard/react
# ECONOMY_PLUGIN_JAR=/absolute/path/to/.local-dev/craftalism-economy.jar
# MARKET_PLUGIN_JAR=/absolute/path/to/.local-dev/craftalism-market.jar
# CLEAN_PLUGIN_BUILD=1
# AUTH_SERVER_DOCKERFILE=Dockerfile
# API_DOCKERFILE=Dockerfile
# DASHBOARD_DOCKERFILE=Dockerfile

# ── Staging/test overrides (optional) ────────────────────────────────────────
# AUTH_SERVER_CI_TAG=main-a1b2c3d
# API_CI_TAG=main-a1b2c3d
# DASHBOARD_CI_TAG=main-a1b2c3d
# AUTH_SERVER_GIT_SHA=a1b2c3d
# API_GIT_SHA=a1b2c3d
# DASHBOARD_GIT_SHA=a1b2c3d
# ECONOMY_GIT_SHA=a1b2c3d
# MARKET_GIT_SHA=a1b2c3d
