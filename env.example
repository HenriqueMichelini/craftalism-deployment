# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=craftalism
DB_PASSWORD=change_me_in_production

# ── Auth Server ───────────────────────────────────────────────────────────────
# Public URL of this auth server (used as JWT issuer claim)
AUTH_ISSUER_URI=https://auth.yourplatform.com

# ── Minecraft Server Client ───────────────────────────────────────────────────
MINECRAFT_CLIENT_ID=minecraft-server
# Generate a strong secret: openssl rand -base64 32
MINECRAFT_CLIENT_SECRET=change_me_in_production

# ── RSA Keys ─────────────────────────────────────────────────────────────────
# Paste as single-line values using literal \n separators.
RSA_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_BASE64_KEY_HERE\n-----END PRIVATE KEY-----
RSA_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nYOUR_BASE64_KEY_HERE\n-----END PUBLIC KEY-----

# ── Release tags used in production mode ─────────────────────────────────────
AUTH_SERVER_VERSION=latest
API_VERSION=latest
DASHBOARD_VERSION=latest
ECONOMY_VERSION=1.5

# ── Test mode repository configuration (optional overrides) ──────────────────
AUTH_SERVER_REPO_URL=https://github.com/HenriqueMichelini/craftalism-authorization-server.git
API_REPO_URL=https://github.com/HenriqueMichelini/craftalism-api.git
DASHBOARD_REPO_URL=https://github.com/HenriqueMichelini/craftalism-dashboard.git
ECONOMY_REPO_URL=https://github.com/HenriqueMichelini/craftalism-economy.git

# Default branch for each repository in test mode
AUTH_SERVER_BRANCH=main
API_BRANCH=main
DASHBOARD_BRANCH=main
ECONOMY_BRANCH=main

# Where test-mode checkouts are created (outside this repo)
TEST_WORKSPACE_ROOT=/tmp/craftalism-test-mode
