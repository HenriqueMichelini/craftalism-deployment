#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT_DIR"

ACTIONS_HELP="Usage: ./prod [up|down]"
ACTION="${1:-up}"
if [[ "$ACTION" != "up" && "$ACTION" != "down" ]]; then
  echo "$ACTIONS_HELP" >&2
  exit 1
fi
if (($# > 0)); then
  shift
fi

read_env_var() {
  local key="$1"
  awk -F= -v key="$key" '$1 == key {sub(/^[^=]*=/, ""); print; exit}' .env
}

load_env_var() {
  local key="$1"
  if [[ -n "${!key:-}" ]]; then
    return 0
  fi
  local value
  value="$(read_env_var "$key" || true)"
  if [[ -n "$value" ]]; then
    export "$key=$value"
  fi
}

require_prod_vars() {
  local missing=()
  local required_vars=(
    AUTH_SERVER_VERSION
    AUTH_SERVER_DIGEST
    API_VERSION
    API_DIGEST
    DASHBOARD_VERSION
    DASHBOARD_DIGEST
    ECONOMY_VERSION
    POSTGRES_VERSION
    POSTGRES_DIGEST
    MINECRAFT_IMAGE_VERSION
    MINECRAFT_IMAGE_DIGEST
    AUTH_ISSUER_URI
    DB_PASSWORD
    MINECRAFT_CLIENT_SECRET
    RSA_PRIVATE_KEY
    RSA_PUBLIC_KEY
    RCON_PASSWORD
  )

  for key in "${required_vars[@]}"; do
    load_env_var "$key"
    if [[ -z "${!key:-}" ]]; then
      missing+=("$key")
    fi
  done

  if (( ${#missing[@]} > 0 )); then
    echo "[prod] Missing required production variables:" >&2
    for key in "${missing[@]}"; do
      echo "  - $key" >&2
    done
    echo "[prod] Set these values in .env or export them before running ./prod up." >&2
    exit 1
  fi
}

validate_prod_runtime_memory() {
  validate_reservation_not_above_limit "auth-server" "${AUTH_SERVER_MEM_LIMIT}" "${AUTH_SERVER_MEM_RESERVATION}"
  validate_reservation_not_above_limit "api" "${API_MEM_LIMIT}" "${API_MEM_RESERVATION}"
  validate_reservation_not_above_limit "postgres" "${POSTGRES_MEM_LIMIT}" "${POSTGRES_MEM_RESERVATION}"
  validate_reservation_not_above_limit "dashboard" "${DASHBOARD_MEM_LIMIT}" "${DASHBOARD_MEM_RESERVATION}"
  validate_reservation_not_above_limit "edge" "${EDGE_MEM_LIMIT}" "${EDGE_MEM_RESERVATION}"
  validate_reservation_not_above_limit "minecraft" "${MINECRAFT_MEM_LIMIT}" "${MINECRAFT_MEM_RESERVATION}"

  validate_java_memory_budget "auth-server" "${AUTH_SERVER_JAVA_TOOL_OPTIONS}" "${AUTH_SERVER_MEM_LIMIT}"
  validate_java_memory_budget "api" "${API_JAVA_TOOL_OPTIONS}" "${API_MEM_LIMIT}"
  validate_minecraft_memory_budget "${MINECRAFT_INIT_MEMORY}" "${MINECRAFT_MEMORY}" "${MINECRAFT_MEM_LIMIT}"
}

if [[ ! -f .env ]]; then
  cp env.example .env
  echo "[prod] Created .env from env.example"
fi

load_env_var CRAFTALISM_RUNTIME_PROFILE
source "$ROOT_DIR/scripts/runtime-profile.sh"
apply_runtime_profile "${CRAFTALISM_RUNTIME_PROFILE:-small-host}"
echo "[prod] Using runtime profile: ${CRAFTALISM_RUNTIME_PROFILE}"

if [[ "$ACTION" == "down" ]]; then
  echo "[prod] Stopping production stack..."
  docker compose down "$@"
  exit 0
fi

require_prod_vars
validate_prod_runtime_memory

digests_refreshed=0
if [[ "${SKIP_DIGEST_REFRESH:-0}" != "1" ]]; then
  echo "[prod] Refreshing image digests in .env..."
  scripts/resolve-image-digests.sh --env-file .env --write
  digests_refreshed=1
else
  echo "[prod] Skipping digest refresh (SKIP_DIGEST_REFRESH=1)"
fi

if [[ "$digests_refreshed" == "1" ]]; then
  echo "[prod] Skipping extra pre-pull because digest refresh already pulled the production images."
else
  echo "[prod] Pre-pulling production images..."
  scripts/prepull-images.sh production
fi

echo "[prod] Starting production stack..."
docker compose up -d "$@"
