#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT_DIR"

ACTIONS_HELP="Usage: ./prod [up|down]"
ACTION="${1:-up}"
if [[ "$ACTION" != "up" && "$ACTION" != "down" ]]; then
  echo "$ACTIONS_HELP" >&2
  exit 1
fi
if (($# > 0)); then
  shift
fi

read_env_var() {
  local key="$1"
  awk -F= -v key="$key" '$1 == key {sub(/^[^=]*=/, ""); print; exit}' .env
}

load_env_var() {
  local key="$1"
  if [[ -n "${!key:-}" ]]; then
    return 0
  fi
  local value
  value="$(read_env_var "$key" || true)"
  if [[ -n "$value" ]]; then
    export "$key=$value"
  fi
}

require_prod_vars() {
  local missing=()
  local required_vars=(
    CADDY_VERSION
    CADDY_DIGEST
    AUTH_SERVER_VERSION
    AUTH_SERVER_DIGEST
    API_VERSION
    API_DIGEST
    DASHBOARD_VERSION
    DASHBOARD_DIGEST
    ECONOMY_VERSION
    POSTGRES_VERSION
    POSTGRES_DIGEST
    MINECRAFT_IMAGE_VERSION
    MINECRAFT_IMAGE_DIGEST
    AUTH_ISSUER_URI
    DB_PASSWORD
    MINECRAFT_CLIENT_SECRET
    RSA_PRIVATE_KEY
    RSA_PUBLIC_KEY
    RCON_PASSWORD
    DASHBOARD_SITE_ADDRESS
    AUTH_SITE_ADDRESS
    DASHBOARD_BASIC_AUTH_USERNAME
    DASHBOARD_BASIC_AUTH_PASSWORD_HASH
  )

  for key in "${required_vars[@]}"; do
    load_env_var "$key"
    if [[ -z "${!key:-}" ]]; then
      missing+=("$key")
    fi
  done

  if (( ${#missing[@]} > 0 )); then
    echo "[prod] Missing required production variables:" >&2
    for key in "${missing[@]}"; do
      echo "  - $key" >&2
    done
    echo "[prod] Set these values in .env or export them before running ./prod up." >&2
    exit 1
  fi
}

if [[ ! -f .env ]]; then
  cp env.example .env
  echo "[prod] Created .env from env.example"
fi

if [[ "$ACTION" == "down" ]]; then
  echo "[prod] Stopping production stack..."
  docker compose --profile production down "$@"
  exit 0
fi

require_prod_vars

if [[ "${SKIP_DIGEST_REFRESH:-0}" != "1" ]]; then
  echo "[prod] Refreshing image digests in .env..."
  scripts/resolve-image-digests.sh --env-file .env --write
else
  echo "[prod] Skipping digest refresh (SKIP_DIGEST_REFRESH=1)"
fi

echo "[prod] Pre-pulling production images..."
scripts/prepull-images.sh production

echo "[prod] Starting production stack..."
docker compose --profile production up -d "$@"
